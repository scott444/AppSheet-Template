# (Optional) Apps Script web app URL — for remote operations
# Deploy as web app from Apps Script editor, set access to "Only myself"
WEBAPP_URL=

# (Optional) AppSheet app ID — for reference in definitions
APPSHEET_APP_ID=

# (Optional) AppSheet application access key — for Data API via Apps Script
# Found in: AppSheet editor > Settings > Integrations > IN: Enable
APPSHEET_ACCESS_KEY=
